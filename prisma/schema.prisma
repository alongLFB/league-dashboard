generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id         String   @id @default(cuid())
  region     String
  alias      String
  summonerId String
  username   String
  password   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
